---
// Reusable submission form: request a topic or offer to give a talk.
---

<form
  id="participate-form"
  class="w-full max-w-xl mx-auto space-y-6 text-black"
  novalidate
>
  <fieldset class="space-y-3">
    <legend class="text-lg font-semibold mb-2">¿Qué querés hacer?</legend>

    <label
      class="flex items-start gap-3 p-3 rounded-lg border border-gray-300 cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-orange-50"
    >
      <input
        type="radio"
        name="type"
        value="topic_request"
        class="mt-1 accent-primary"
        checked
      />
      <span>
        <span class="font-semibold block">Sugerir un tema</span>
        <span class="text-gray-600 text-sm"
          >Te gustaría que alguien presentara algo en una meetup.</span
        >
      </span>
    </label>

    <label
      class="flex items-start gap-3 p-3 rounded-lg border border-gray-300 cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-orange-50"
    >
      <input
        type="radio"
        name="type"
        value="speaker_offer"
        class="mt-1 accent-primary"
      />
      <span>
        <span class="font-semibold block">Dar una charla</span>
        <span class="text-gray-600 text-sm"
          >Querés dar una charla vos. Te contactamos para coordinar.</span
        >
      </span>
    </label>
  </fieldset>

  <div>
    <label for="pf-name" class="block font-semibold mb-1">Nombre</label>
    <input
      id="pf-name"
      name="name"
      type="text"
      required
      autocomplete="name"
      class="w-full px-3 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-primary"
    />
  </div>

  <div>
    <label for="pf-email" class="block font-semibold mb-1">
      Email <span id="pf-email-hint" class="text-gray-500 font-normal text-sm">(opcional)</span>
    </label>
    <input
      id="pf-email"
      name="email"
      type="email"
      autocomplete="email"
      class="w-full px-3 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-primary"
    />
  </div>

  <div>
    <label for="pf-message" class="block font-semibold mb-1">
      <span id="pf-message-label">Tema que te gustaría ver</span>
    </label>
    <textarea
      id="pf-message"
      name="message"
      rows="5"
      required
      class="w-full px-3 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-primary"
    ></textarea>
  </div>

  <button
    type="submit"
    id="pf-submit"
    class="appearance-none py-2 px-4 bg-primary text-white font-semibold rounded-lg shadow-md hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:ring-opacity-75 disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Enviar
  </button>

  <p id="pf-status" role="status" aria-live="polite" class="text-sm"></p>
</form>

<script>
  const form = document.getElementById('participate-form') as HTMLFormElement;
  const emailInput = document.getElementById('pf-email') as HTMLInputElement;
  const emailHint = document.getElementById('pf-email-hint') as HTMLSpanElement;
  const messageLabel = document.getElementById('pf-message-label') as HTMLSpanElement;
  const submitBtn = document.getElementById('pf-submit') as HTMLButtonElement;
  const status = document.getElementById('pf-status') as HTMLParagraphElement;

  function selectedType(): string {
    const checked = form.querySelector<HTMLInputElement>('input[name="type"]:checked');
    return checked ? checked.value : 'topic_request';
  }

  function syncForType() {
    const isSpeaker = selectedType() === 'speaker_offer';
    emailInput.required = isSpeaker;
    emailHint.textContent = isSpeaker ? '(obligatorio)' : '(opcional)';
    messageLabel.textContent = isSpeaker
      ? 'Sobre qué querés hablar'
      : 'Tema que te gustaría ver';
  }

  form
    .querySelectorAll('input[name="type"]')
    .forEach((el) => el.addEventListener('change', syncForType));
  syncForType();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = '';
    status.className = 'text-sm';

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const payload = {
      type: selectedType(),
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando…';

    try {
      const res = await fetch('/api/submissions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        form.reset();
        syncForType();
        status.textContent = '¡Gracias! Recibimos tu mensaje.';
        status.className = 'text-sm text-green-700 font-semibold';
      } else {
        status.textContent = data.error || 'Algo salió mal. Intentá de nuevo.';
        status.className = 'text-sm text-red-600 font-semibold';
      }
    } catch {
      status.textContent = 'No se pudo conectar. Revisá tu conexión e intentá de nuevo.';
      status.className = 'text-sm text-red-600 font-semibold';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar';
    }
  });
</script>
